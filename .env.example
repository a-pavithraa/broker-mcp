# =============================================================================
# .env.example - copy to .env and fill in your values
# =============================================================================
# The .env file is gitignored - never commit it.
#
# MINIMUM SETUP
# -------------
# 1. Fill in the API key + secret for the broker(s) you use (Section 1 and/or 2).
# 2. Run:  ./refresh_trading_sessions.sh
#
# That script logs you in, writes fresh session tokens to
# ~/.broker-mcp/.env.session, updates your MCP config, and restarts
# Claude Desktop automatically.
#
# User ID and password are optional here — if omitted, the login script
# will prompt you interactively at runtime.
#
# Everything below Section 2 is optional - skip it until you need it.
# =============================================================================


# =============================================================================
# SECTION 1 - ICICI Direct (Breeze)
# Skip this section entirely if you only use Zerodha.
# =============================================================================

# Required — minimum for broker detection
BREEZE_API_KEY=your_api_key_here        # from https://api.icicidirect.com/
BREEZE_SECRET=your_api_secret_here

# Optional — if omitted, the login script prompts interactively
# ICICI_USER_ID=your_user_id
# ICICI_PASSWORD=your_password


# =============================================================================
# SECTION 2 - Zerodha
# Skip this section entirely if you only use Breeze.
# =============================================================================

# Required — minimum for broker detection
ZERODHA_API_KEY=your_zerodha_api_key    # from https://kite.trade/
ZERODHA_API_SECRET=your_zerodha_api_secret

# Optional — if omitted, the login script prompts interactively
# ZERODHA_USER_ID=your_zerodha_user_id
# ZERODHA_PASSWORD=your_zerodha_password


# =============================================================================
# SECTION 3 - Automation helpers  (optional but recommended)
# =============================================================================

# Zerodha 2FA - set this and 2FA is submitted automatically during login.
# Find the base32 seed in your authenticator app under "Show key" / setup screen.
# Without it, the browser opens and you enter the 6-digit code manually.
# ZERODHA_TOTP_SECRET=

# Breeze OTP - set these and the OTP is read from Gmail automatically.
# Without them, the script pauses and prompts you to type the OTP.
# Setup (5 min): enable Gmail IMAP + generate an App Password at
#   https://myaccount.google.com/apppasswords
# GMAIL_USER=your.email@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password_no_spaces


# =============================================================================
# SECTION 4 - Zerodha FIFO tax reporting  (optional)
# Only needed if you want accurate LTCG/STCG calculations from historical trades.
# =============================================================================

# All paths default to ~/.broker-mcp/ — override only if needed.
# ZERODHA_TRADEBOOK_IMPORT_ROOT=~/.broker-mcp/imports
# ZERODHA_TRADEBOOK_STORE_PATH=~/.broker-mcp/zerodha-tradebook.json
# BROKER_CORPORATE_ACTIONS_STORE_PATH=~/.broker-mcp/stock-corporate-actions.json

# On startup the server imports all CSVs found under ZERODHA_TRADEBOOK_IMPORT_ROOT.

# Auto-download Zerodha tradebook CSVs after each login.
# The exporter covers BROKER_TRADE_HISTORY_YEARS years and splits requests into 365-day chunks.
# ZERODHA_TRADEBOOK_AUTO_EXPORT=true
# ZERODHA_TRADEBOOK_FILENAME=zerodha-tradebook.csv
# ZERODHA_TRADEBOOK_SEGMENT=Equity


# =============================================================================
# SECTION 5 - Advanced / rarely needed
# =============================================================================

# Tool access level.
#   readonly  - market data and reporting only (default, safe)
#   full      - also enables order placement, tradebook import, and corporate-action write tools
# BROKER_TOOLS_MODE=readonly

# Trading guard rail - must be set to true alongside BROKER_TOOLS_MODE=full to place orders.
# BROKER_TRADING_ENABLED=false
# BROKER_MAX_ORDER_VALUE=5000
# BROKER_TRADE_LOG_PATH=~/.broker-mcp/logs/trade-executions.log

# How many years of trade history to load for tax calculations.
# BROKER_TRADE_HISTORY_YEARS=5

# Which exchanges to include when fetching trades (comma-separated).
# BROKER_TRADE_EXCHANGES=NSE,BSE

# Sector enrichment for holdings (uses stock-universe.csv metadata).
# BROKER_SECTOR_ENRICHMENT=true

# Hide the browser window during login (headless mode).
# Only enable after confirming login works in visible mode.
# Breeze headless requires Gmail (Section 3). Zerodha headless requires TOTP (Section 3).
# BREEZE_HEADLESS=true
# ZERODHA_HEADLESS=true

# Shared Playwright browser profile - lets zerodha_login.py and
# zerodha_tradebook.py reuse the same browser session/cookies.
# ZERODHA_BROWSER_STATE_DIR=~/.broker-mcp/playwright/zerodha

# Docker image name - used when printing the docker run command after token refresh.
# Only relevant if you run the MCP server as a Docker container.
# DOCKER_IMAGE=broker-mcp
